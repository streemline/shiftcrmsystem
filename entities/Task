{
  "name": "Task",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "deadline": {
      "type": "string",
      "format": "date"
    },
    "progress": {
      "type": "number",
      "description": "\u041f\u0440\u043e\u0433\u0440\u0435\u0441\u0441 0-100"
    },
    "status": {
      "type": "string",
      "enum": [
        "todo",
        "in_progress",
        "completed"
      ],
      "default": "todo"
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "normal",
        "high"
      ],
      "default": "normal"
    },
    "assigned_to": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "\u041c\u0430\u0441\u0441\u0438\u0432 email \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u043e\u0432"
    },
    "created_by": {
      "type": "string"
    },
    "photo_urls": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "URL \u0444\u043e\u0442\u043e\u043e\u0442\u0447\u0451\u0442\u043e\u0432"
    }
  },
  "required": [
    "title"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    },
    "write": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}