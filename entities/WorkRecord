{
  "name": "WorkRecord",
  "type": "object",
  "properties": {
    "employee_id": {
      "type": "string",
      "description": "Email \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u0430"
    },
    "employee_name": {
      "type": "string",
      "description": "\u0418\u043c\u044f \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u0430 \u0434\u043b\u044f \u043e\u0442\u0447\u0451\u0442\u043e\u0432"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "start_time": {
      "type": "string",
      "description": "\u0424\u043e\u0440\u043c\u0430\u0442 HH:MM, \u043d\u0430\u043f\u0440\u0438\u043c\u0435\u0440 08:00"
    },
    "end_time": {
      "type": "string",
      "description": "\u0424\u043e\u0440\u043c\u0430\u0442 HH:MM, \u043d\u0430\u043f\u0440\u0438\u043c\u0435\u0440 17:00"
    },
    "duration_hours": {
      "type": "number",
      "description": "\u041a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u0447\u0430\u0441\u043e\u0432, \u0430\u0432\u0442\u043e\u043c\u0430\u0442\u0438\u0447\u0435\u0441\u043a\u0438, \u0443\u0447\u0451\u0442 \u043d\u043e\u0447\u043d\u044b\u0445 \u0441\u043c\u0435\u043d"
    },
    "object_type": {
      "type": "string",
      "enum": [
        "\u041f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u0441\u0442\u0432\u043e",
        "\u041c\u043e\u043d\u0442\u0430\u0436",
        "\u0414\u0435\u043c\u043e\u043d\u0442\u0430\u0436",
        "\u0414\u0440\u0443\u0433\u043e\u0435"
      ]
    },
    "day_type": {
      "type": "string",
      "enum": [
        "Working",
        "Sick",
        "Day Off",
        "Vacation"
      ],
      "default": "Working"
    },
    "earnings": {
      "type": "number",
      "description": "\u0417\u0430\u0440\u0430\u0431\u043e\u0442\u043e\u043a: duration_hours \u00d7 hourly_rate"
    },
    "hourly_rate_snapshot": {
      "type": "number",
      "description": "\u041f\u043e\u0447\u0430\u0441\u043e\u0432\u0430\u044f \u0441\u0442\u0430\u0432\u043a\u0430 \u043d\u0430 \u043c\u043e\u043c\u0435\u043d\u0442 \u0437\u0430\u043f\u0438\u0441\u0438"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "employee_id",
    "date",
    "day_type"
  ]
}