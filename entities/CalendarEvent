{
  "name": "CalendarEvent",
  "type": "object",
  "properties": {
    "date": {
      "type": "string",
      "format": "date",
      "description": "\u0414\u0430\u0442\u0430 \u043d\u0430\u0447\u0430\u043b\u0430"
    },
    "end_date": {
      "type": "string",
      "format": "date",
      "description": "\u0414\u0430\u0442\u0430 \u043e\u043a\u043e\u043d\u0447\u0430\u043d\u0438\u044f (\u043d\u0435\u043e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u043d\u043e)"
    },
    "start_time": {
      "type": "string",
      "description": "\u0412\u0440\u0435\u043c\u044f \u043d\u0430\u0447\u0430\u043b\u0430 HH:MM"
    },
    "end_time": {
      "type": "string",
      "description": "\u0412\u0440\u0435\u043c\u044f \u043e\u043a\u043e\u043d\u0447\u0430\u043d\u0438\u044f HH:MM"
    },
    "title": {
      "type": "string"
    },
    "event_type": {
      "type": "string",
      "enum": [
        "\u041f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u0441\u0442\u0432\u043e",
        "\u0412\u044b\u0441\u0442\u0430\u0432\u043a\u0430",
        "\u0412\u044b\u0445\u043e\u0434\u043d\u043e\u0439",
        "\u0414\u0440\u0443\u0433\u043e\u0435"
      ]
    },
    "description": {
      "type": "string"
    },
    "assigned_employees": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Email \u0441\u043e\u0442\u0440\u0443\u0434\u043d\u0438\u043a\u043e\u0432. \u041f\u0443\u0441\u0442\u043e\u0439 \u043c\u0430\u0441\u0441\u0438\u0432 = \u0434\u043b\u044f \u0432\u0441\u0435\u0445"
    },
    "color": {
      "type": "string",
      "description": "\u0426\u0432\u0435\u0442 \u043c\u0435\u0442\u043a\u0438 hex"
    }
  },
  "required": [
    "date",
    "title",
    "event_type"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    },
    "write": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}